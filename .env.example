# Supabase Configuration
# Dapatkan URL dan Anon Key dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Drive API — OAuth Refresh Token (server-side upload)
# 1. Buat OAuth Client ID (Desktop app) di Google Cloud Console
# 2. Isi GOOGLE_CLIENT_ID dan GOOGLE_CLIENT_SECRET
# 3. Admin buka /admin/google-setup dan login sekali untuk mendapat refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
